<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WARP3 Ladeabrechnung</title>
    <style>
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:#f5f5f5;color:#333;padding:20px}
        .container{max-width:1100px;margin:0 auto}
        h1{margin-bottom:20px;font-size:1.5em}
        .filter-bar{background:#fff;padding:16px 20px;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);margin-bottom:20px;display:flex;gap:16px;align-items:end;flex-wrap:wrap}
        .filter-bar label{font-size:.85em;font-weight:600;display:block;margin-bottom:4px}
        .filter-bar select{padding:6px 10px;border:1px solid #ccc;border-radius:4px;font-size:.9em}
        .filter-bar button,.btn{padding:7px 18px;border:none;border-radius:4px;font-size:.9em;cursor:pointer;text-decoration:none;display:inline-block}
        .btn-pdf{background:#16a34a;color:#fff}.btn-pdf:hover{background:#15803d}
        .btn-grey{background:#666;color:#fff;padding:7px 14px}
        .btn-dark{background:#888;color:#fff;padding:7px 14px}
        .summary{background:#fff;padding:14px 20px;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);margin-bottom:20px;display:flex;gap:30px;flex-wrap:wrap}
        .stat .val{font-size:1.4em;font-weight:700}
        .stat .lbl{font-size:.8em;color:#666}
        table{width:100%;border-collapse:collapse;background:#fff;border-radius:8px;overflow:hidden;box-shadow:0 1px 3px rgba(0,0,0,.1)}
        th{background:#f8f8f8;text-align:left;padding:10px 12px;font-size:.8em;font-weight:600;border-bottom:2px solid #e5e5e5}
        td{padding:8px 12px;font-size:.85em;border-bottom:1px solid #eee}
        tr:hover td{background:#f0f7ff}
        .error{background:#fef2f2;color:#b91c1c;padding:14px 20px;border-radius:8px;margin-bottom:20px}
        .num{text-align:right;font-variant-numeric:tabular-nums}
        .company-form{display:none;background:#fff;padding:14px 20px;border-radius:8px;box-shadow:0 1px 3px rgba(0,0,0,.1);margin-bottom:20px;gap:12px;align-items:end;flex-wrap:wrap}
        .company-form input{padding:6px 10px;border:1px solid #ccc;border-radius:4px;font-size:.9em}
        .company-form label{font-size:.85em;font-weight:600;display:block;margin-bottom:4px}
    </style>
</head>
<body>
<div class="container">
    <h1>⚡ WARP3 Ladeabrechnung</h1>

    <% if (error) { %>
    <div class="error">Fehler beim Abrufen der Wallbox-Daten: <%= error %></div>
    <% } %>

    <div class="filter-bar">
        <div>
            <label>Benutzer</label>
            <select id="user" onchange="applyFilters()">
                <option value="">Alle Benutzer</option>
                <% Object.entries(users).forEach(([uid, name]) => { %>
                <option value="<%= uid %>" <%= selUser == uid ? 'selected' : '' %>><%= name %></option>
                <% }) %>
            </select>
        </div>
        <div>
            <label>Jahr</label>
            <select id="year" onchange="applyFilters()">
                <option value="">Alle</option>
                <% const curYear = new Date().getFullYear(); for (let y = curYear; y >= curYear - 3; y--) { %>
                <option value="<%= y %>" <%= (selMonth && selMonth.startsWith(String(y))) || selYear == String(y) ? 'selected' : '' %>><%= y %></option>
                <% } %>
            </select>
        </div>
        <div>
            <label>Monat</label>
            <select id="month" onchange="applyFilters()">
                <option value="">Alle</option>
                <% ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'].forEach((m, i) => { %>
                <option value="<%= String(i+1).padStart(2,'0') %>" <%= selMonth && selMonth.endsWith('-'+String(i+1).padStart(2,'0')) ? 'selected' : '' %>><%= m %></option>
                <% }) %>
            </select>
        </div>
        <button class="btn-pdf" onclick="downloadPdf()">PDF Export</button>
        <a href="/refresh" class="btn btn-grey">↻ Aktualisieren</a>
        <button class="btn btn-dark" onclick="document.querySelector('.company-form').style.display=document.querySelector('.company-form').style.display==='flex'?'none':'flex'">⚙ Briefkopf</button>
    </div>

    <form class="company-form" method="post" action="/company">
        <div>
            <label>Firma</label>
            <input name="name" value="<%= company.name %>" style="width:250px">
        </div>
        <div>
            <label>Straße</label>
            <input name="street" value="<%= company.street %>" style="width:200px">
        </div>
        <div>
            <label>PLZ / Ort</label>
            <input name="city" value="<%= company.city %>" style="width:200px">
        </div>
        <button type="submit" style="background:#2563eb;color:#fff" class="btn">Speichern</button>
    </form>

    <% if (rows.length > 0) { %>
    <div class="summary">
        <div class="stat"><div class="val"><%= rows.length %></div><div class="lbl">Ladevorgänge</div></div>
        <div class="stat"><div class="val"><%= de(totalKwh, 3) %> kWh</div><div class="lbl">Gesamtenergie</div></div>
        <div class="stat"><div class="val"><%= de(totalCost, 2) %> €</div><div class="lbl">Gesamtkosten</div></div>
        <% Object.entries(prices).forEach(([name, price]) => { %>
        <div class="stat"><div class="val"><%= de(price, 2) %> ct/kWh</div><div class="lbl"><%= name %></div></div>
        <% }) %>
    </div>

    <table>
        <thead>
            <tr>
                <th>Startzeit</th>
                <th>Benutzer</th>
                <th>Wallbox</th>
                <th class="num">Zählerstand Start</th>
                <th class="num">geladen (kWh)</th>
                <th>Ladedauer</th>
                <th class="num">Kosten (€)</th>
            </tr>
        </thead>
        <tbody>
            <% rows.forEach(r => { %>
            <tr>
                <td><%= r.date %></td>
                <td><%= r.user %></td>
                <td><%= r.wallbox %></td>
                <td class="num"><%= r.kwhStart !== null ? de(r.kwhStart, 3) : '–' %></td>
                <td class="num"><%= r.energy !== null ? de(r.energy, 3) : '–' %></td>
                <td><%= r.duration %></td>
                <td class="num"><%= de(r.cost, 2) %></td>
            </tr>
            <% }) %>
        </tbody>
    </table>
    <% } else if (!error) { %>
    <p style="padding:20px;background:#fff;border-radius:8px;">Keine Ladevorgänge für die gewählten Filter gefunden.</p>
    <% } %>
</div>

<script>
function buildParams() {
    const p = new URLSearchParams();
    const user = document.getElementById('user').value;
    const year = document.getElementById('year').value;
    const month = document.getElementById('month').value;
    if (user) p.set('user', user);
    if (year && month) p.set('month', year + '-' + month);
    else if (year) p.set('year', year);
    return p;
}

function applyFilters() {
    window.location.href = '/?' + buildParams().toString();
}

function downloadPdf() {
    window.location.href = '/pdf?' + buildParams().toString();
}
</script>
</body>
</html>