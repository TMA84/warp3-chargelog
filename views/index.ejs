<!DOCTYPE html>
<html lang="de">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WARP3 Ladeabrechnung</title>
    <style>
        :root{--primary:#1a56db;--primary-hover:#1e40af;--success:#059669;--success-hover:#047857;--gray-50:#f9fafb;--gray-100:#f3f4f6;--gray-200:#e5e7eb;--gray-300:#d1d5db;--gray-500:#6b7280;--gray-600:#4b5563;--gray-700:#374151;--gray-800:#1f2937;--gray-900:#111827;--red-50:#fef2f2;--red-700:#b91c1c;--radius:6px;--shadow:0 1px 3px rgba(0,0,0,.08),0 1px 2px rgba(0,0,0,.06)}
        *{box-sizing:border-box;margin:0;padding:0}
        body{font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,sans-serif;background:var(--gray-100);color:var(--gray-900);font-size:14px;line-height:1.5}
        .container{max-width:1200px;margin:0 auto;padding:24px}
        .header{display:flex;align-items:center;justify-content:space-between;margin-bottom:24px;padding-bottom:16px;border-bottom:1px solid var(--gray-200)}
        .header h1{font-size:1.25rem;font-weight:600;color:var(--gray-800)}
        .header-actions{display:flex;gap:8px}
        .card{background:#fff;border:1px solid var(--gray-200);border-radius:var(--radius);box-shadow:var(--shadow)}
        .filter-bar{padding:16px 20px;margin-bottom:16px;display:flex;gap:14px;align-items:end;flex-wrap:wrap}
        .filter-bar .field label{display:block;font-size:12px;font-weight:500;color:var(--gray-500);margin-bottom:4px;text-transform:uppercase;letter-spacing:.03em}
        .filter-bar select,.filter-bar input[type="date"]{padding:7px 10px;border:1px solid var(--gray-300);border-radius:var(--radius);font-size:13px;color:var(--gray-700);background:#fff;min-width:120px}
        .filter-bar select:focus{outline:none;border-color:var(--primary);box-shadow:0 0 0 2px rgba(26,86,219,.15)}
        .btn{display:inline-flex;align-items:center;gap:6px;padding:7px 16px;border:1px solid transparent;border-radius:var(--radius);font-size:13px;font-weight:500;cursor:pointer;text-decoration:none;transition:background .15s,border-color .15s}
        .btn-primary{background:var(--primary);color:#fff}.btn-primary:hover{background:var(--primary-hover)}
        .btn-success{background:var(--success);color:#fff}.btn-success:hover{background:var(--success-hover)}
        .btn-outline{background:#fff;color:var(--gray-700);border-color:var(--gray-300)}.btn-outline:hover{background:var(--gray-50);border-color:var(--gray-400)}
        .stats{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:16px;margin-bottom:16px}
        .stat-card{padding:16px 20px}
        .stat-card .value{font-size:1.35rem;font-weight:700;color:var(--gray-900)}
        .stat-card .label{font-size:12px;color:var(--gray-500);margin-top:2px}
        table{width:100%;border-collapse:collapse}
        .table-wrap{margin-bottom:24px;overflow-x:auto}
        thead th{background:var(--gray-50);text-align:left;padding:10px 16px;font-size:12px;font-weight:600;color:var(--gray-500);text-transform:uppercase;letter-spacing:.03em;border-bottom:2px solid var(--gray-200)}
        tbody td{padding:10px 16px;font-size:13px;color:var(--gray-700);border-bottom:1px solid var(--gray-100)}
        tbody tr:hover td{background:var(--gray-50)}
        .num{text-align:right;font-variant-numeric:tabular-nums;font-feature-settings:"tnum"}
        th.num{text-align:right}
        .error{background:var(--red-50);color:var(--red-700);padding:14px 20px;border-radius:var(--radius);margin-bottom:16px;border:1px solid #fecaca}
        .empty{padding:32px 20px;text-align:center;color:var(--gray-500)}
        .company-panel{display:none;padding:16px 20px;margin-bottom:16px;gap:14px;align-items:end;flex-wrap:wrap}
        .company-panel input{padding:7px 10px;border:1px solid var(--gray-300);border-radius:var(--radius);font-size:13px;color:var(--gray-700)}
        .company-panel label{display:block;font-size:12px;font-weight:500;color:var(--gray-500);margin-bottom:4px;text-transform:uppercase;letter-spacing:.03em}
        .divider{width:1px;height:28px;background:var(--gray-200);align-self:center}
    </style>
</head>
<body>
<div class="container">
    <div class="header">
        <h1>WARP3 Ladeabrechnung</h1>
        <div class="header-actions">
            <a href="/refresh" class="btn btn-outline">Aktualisieren</a>
            <button class="btn btn-outline" onclick="document.querySelector('.company-panel').style.display=document.querySelector('.company-panel').style.display==='flex'?'none':'flex'">Briefkopf</button>
        </div>
    </div>

    <% if (error) { %>
    <div class="error">Fehler beim Abrufen der Wallbox-Daten: <%= error %></div>
    <% } %>

    <form class="card company-panel" method="post" action="/company">
        <div class="field">
            <label>Firma</label>
            <input name="name" value="<%= company.name %>" style="width:250px">
        </div>
        <div class="field">
            <label>Strasse</label>
            <input name="street" value="<%= company.street %>" style="width:200px">
        </div>
        <div class="field">
            <label>PLZ / Ort</label>
            <input name="city" value="<%= company.city %>" style="width:200px">
        </div>
        <button type="submit" class="btn btn-primary">Speichern</button>
    </form>

    <div class="card filter-bar">
        <div class="field">
            <label>Benutzer</label>
            <select id="user" onchange="applyFilters()">
                <option value="">Alle Benutzer</option>
                <% Object.entries(users).forEach(([uid, name]) => { %>
                <option value="<%= uid %>" <%= selUser == uid ? 'selected' : '' %>><%= name %></option>
                <% }) %>
            </select>
        </div>
        <div class="field">
            <label>Jahr</label>
            <select id="year" onchange="applyFilters()">
                <option value="">Alle</option>
                <% const curYear = new Date().getFullYear(); for (let y = curYear; y >= curYear - 3; y--) { %>
                <option value="<%= y %>" <%= (selMonth && selMonth.startsWith(String(y))) || selYear == String(y) ? 'selected' : '' %>><%= y %></option>
                <% } %>
            </select>
        </div>
        <div class="field">
            <label>Monat</label>
            <select id="month" onchange="applyFilters()">
                <option value="">Alle</option>
                <% ['Januar','Februar','März','April','Mai','Juni','Juli','August','September','Oktober','November','Dezember'].forEach((m, i) => { %>
                <option value="<%= String(i+1).padStart(2,'0') %>" <%= selMonth && selMonth.endsWith('-'+String(i+1).padStart(2,'0')) ? 'selected' : '' %>><%= m %></option>
                <% }) %>
            </select>
        </div>
        <div class="divider"></div>
        <div class="field">
            <label>Von</label>
            <input type="date" id="from" value="<%= selFrom %>" onchange="applyFilters()">
        </div>
        <div class="field">
            <label>Bis</label>
            <input type="date" id="to" value="<%= selTo %>" onchange="applyFilters()">
        </div>
        <div class="divider"></div>
        <button type="button" class="btn btn-success" onclick="downloadPdf()">PDF exportieren</button>
    </div>

    <% if (rows.length > 0) { %>
    <div class="stats">
        <div class="card stat-card"><div class="value"><%= rows.length %></div><div class="label">Ladevorgänge</div></div>
        <div class="card stat-card"><div class="value"><%= de(totalKwh, 3) %> kWh</div><div class="label">Gesamtenergie</div></div>
        <div class="card stat-card"><div class="value"><%= de(totalCost, 2) %> EUR</div><div class="label">Gesamtkosten</div></div>
        <% Object.entries(prices).forEach(([name, price]) => { %>
        <div class="card stat-card"><div class="value"><%= de(price, 2) %> ct/kWh</div><div class="label"><%= name %></div></div>
        <% }) %>
    </div>

    <div class="card table-wrap">
    <table>
        <thead>
            <tr>
                <th>Startzeit</th>
                <th>Benutzer</th>
                <th>Wallbox</th>
                <th class="num">Zählerstand Start</th>
                <th class="num">geladen (kWh)</th>
                <th>Ladedauer</th>
                <th class="num">Kosten (EUR)</th>
            </tr>
        </thead>
        <tbody>
            <% rows.forEach(r => { %>
            <tr>
                <td><%= r.date %></td>
                <td><%= r.user %></td>
                <td><%= r.wallbox %></td>
                <td class="num"><%= r.kwhStart !== null ? de(r.kwhStart, 3) : '–' %></td>
                <td class="num"><%= r.energy !== null ? de(r.energy, 3) : '–' %></td>
                <td><%= r.duration %></td>
                <td class="num"><%= de(r.cost, 2) %></td>
            </tr>
            <% }) %>
        </tbody>
    </table>
    </div>
    <% } else if (!error) { %>
    <div class="card"><p class="empty">Keine Ladevorgänge für die gewählten Filter gefunden.</p></div>
    <% } %>
</div>

<script>
function buildParams() {
    const p = new URLSearchParams();
    const user = document.getElementById('user').value;
    const year = document.getElementById('year').value;
    const month = document.getElementById('month').value;
    const from = document.getElementById('from').value;
    const to = document.getElementById('to').value;
    if (user) p.set('user', user);
    if (year && month) p.set('month', year + '-' + month);
    else if (year) p.set('year', year);
    if (from) p.set('from', from);
    if (to) p.set('to', to);
    return p;
}
function applyFilters() { window.location.href = '/?' + buildParams().toString(); }
function downloadPdf() { window.location.href = '/pdf?' + buildParams().toString(); }
</script>
</body>
</html>